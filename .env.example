# System Database (PostgreSQL / Supabase / Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frameforge?schema=public"

# Redis Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://your-redis-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_redis_token"

# JWT Auths & Sessions
NEXTAUTH_SECRET="your_nextauth_jwt_signing_key_32_bytes"
NEXTAUTH_URL="http://localhost:3000"

# Storage Configuration (Cloudflare R2 Bucket / AWS S3)
R2_ACCESS_KEY_ID="cloudflare_r2_access_key"
R2_SECRET_ACCESS_KEY="cloudflare_r2_secret_key"
R2_ENDPOINT_URL="https://<account_id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="frameforge-prod-media"

# Third-Party API Integrations
STRIPE_SECRET_KEY="sk_test_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_stripe_signing_key"
RESEND_API_KEY="re_resend_email_api_key"
GEMINI_API_KEY="google_gemini_vision_api_key"

# Legacy Portfolio Environment (If applicable)
MONGODB_URI="mongodb+srv://..."
ADMIN_PASSWORD="your_admin_password"
