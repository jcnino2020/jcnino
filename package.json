{
  "name": "frameforge-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "FrameForge (Moments OS) Creative Operations SaaS Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "mongodb": "^6.5.0",
    "@tailwindcss/cli": "^4.0.0"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "legacy:build": "tailwindcss -i assets/tailwind.input.css -o assets/tailwind.css --minify",
    "legacy:watch": "tailwindcss -i assets/tailwind.input.css -o assets/tailwind.css --watch"
  }
}
